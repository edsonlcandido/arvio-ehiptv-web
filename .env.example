# ARVIO Web — environment variables
# Copy this file to .env.local and fill in real values.

# --- Supabase (optional; falls back to local mode when absent) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Trakt ---
NEXT_PUBLIC_TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=

# --- TMDB (server-side, only used without Supabase) ---
TMDB_API_KEY=

# --- STREAM PROXY ---
# Comma-separated allowlist of upstream hostnames the /api/proxy route will
# fetch from. Leave empty (default) to allow any host. Recommended for
# production: list only your IPTV provider's hostname(s).
# Example: PROXY_ALLOWED_HOSTS=iptv.example.com,cdn.iptv.example.com
PROXY_ALLOWED_HOSTS=

# Optional shared secret. When set, callers must pass ?key=<this> on every
# /api/proxy request. Adds brute-force protection against random scanners
# abusing your server as an open proxy.
PROXY_SHARED_KEY=

# Public origin the proxy uses when rewriting HLS segment URLs inside a
# manifest. Only set this if your reverse proxy does NOT forward
# `Host` / `X-Forwarded-Host` (e.g. a non-standard tunnel, a CDN that
# strips headers, etc.). Most setups should leave it empty — the proxy
# will pick up the headers automatically.
# Format: scheme + host[:port], no trailing slash.
# Examples:
#   PUBLIC_BASE_URL=https://ehiptv.com
#   PUBLIC_BASE_URL=https://app.ehiptv.com:8443
PUBLIC_BASE_URL=